{
  "name": "wangcai-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production node .next/standalone/server.js",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "electron:dev": "electron electron/main.js",
    "electron:build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/ && electron-builder --win --x64",
    "electron:linux": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/ && electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.wangcai.desktop",
    "productName": "旺财",
    "directories": { "output": "release" },
    "files": ["electron/**/*", ".next/standalone/**/*", ".next/static/**/*", "public/**/*", "package.json"],
    "win": { "target": "nsis", "icon": "public/wangcai-logo.png" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "createDesktopShortcut": true, "shortcutName": "旺财" }
  },
  "dependencies": {
    "next": "^16.1.1", "react": "^19.0.0", "react-dom": "^19.0.0",
    "zustand": "^5.0.6", "socket.io-client": "^4.8.3",
    "z-ai-web-dev-sdk": "^0.0.18", "weixin-agent-sdk": "^0.5.0",
    "prisma": "^6.11.1", "@prisma/client": "^6.11.1",
    "sonner": "^2.0.6", "lucide-react": "^0.525.0",
    "clsx": "^2.1.1", "tailwind-merge": "^3.3.1",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.23.2", "recharts": "^2.15.4",
    "date-fns": "^4.1.0", "uuid": "^11.1.0",
    "tailwindcss": "^4", "@tailwindcss/postcss": "^4",
    "tw-animate-css": "^1.3.5",
    "next-themes": "^0.4.6"
  },
  "devDependencies": {
    "electron": "^42.4.1", "electron-builder": "^26.15.3",
    "typescript": "^5", "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "@types/react": "^19", "@types/react-dom": "^19"
  }
}
