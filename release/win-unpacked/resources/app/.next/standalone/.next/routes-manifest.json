      "page": "/api/waos/brain/proxy/[...path]",
      "regex": "^/api/waos/brain/proxy/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/waos/brain/proxy/(?<nxtPpath>.+?)(?:/)?$"
    }
  ],
