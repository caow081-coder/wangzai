{
  "name": "wangcai-desktop",
  "version": "1.0.0",
  "description": "旺财 WAOS - AI 私域营销助手，专为奔驰销售运营设计",
  "author": "Wangcai WAOS",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "postbuild": "node scripts/copy-assets.js",
    "start": "node .next/standalone/server.js",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "electron:dev": "electron electron/main.js",
    "electron:build": "next build && node scripts/copy-assets.js && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.wangcai.desktop",
    "productName": "旺财",
    "copyright": "Copyright © 2026 旺财 WAOS",
    "directories": {
      "output": "release",
      "buildResources": "electron/build"
    },
    "asar": false,
    "files": [
      "electron/**/*",
      "!electron/build/**",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "prisma/**/*",
      "db/**/*",
      "package.json",
      "!**/.DS_Store",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}"
    ],
    "extraResources": [
      {
        "from": "db",
        "to": "db",
        "filter": ["**/*"]
      },
      {
        "from": "prisma",
        "to": "prisma",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/build/icon.png",
      "artifactName": "旺财 Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/build/icon.png",
      "uninstallerIcon": "electron/build/icon.png",
      "installerHeaderIcon": "electron/build/icon.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "旺财",
      "uninstallDisplayName": "旺财 ${version}",
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "language": "2052"
    },
    "publish": {
      "provider": "github",
      "owner": "caow081-coder",
      "repo": "wangzai",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.1.1",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tailwindcss/postcss": "^4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.23.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.6",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "react-resizable-panels": "^3.0.3",
    "recharts": "^2.15.4",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "weixin-agent-sdk": "^0.5.0",
    "z-ai-web-dev-sdk": "^0.0.18",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.4"
  }
}
